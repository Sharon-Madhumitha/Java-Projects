CREATE DATABASE crime_db;
USE crime_db;
CREATE TABLE crime_records
(
crime_id INT PRIMARY KEY AUTO_INCREMENT,
criminal_name VARCHAR(100),
crime_type VARCHAR(100),
location VARCHAR(100),
date DATE,
status VARCHAR(50),
officer_name VARCHAR(100)
);

DBConeection.java

import java.sql.*;

public class DBConnection {

    static final String URL = "jdbc:mysql://localhost:3306/crime_db";
    static final String USER = "root";
    static final String PASSWORD = "root";

    public static Connection getConnection() {

        try {

            Class.forName("com.mysql.cj.jdbc.Driver");

            return DriverManager.getConnection(URL, USER, PASSWORD);

        } catch(Exception e) {

            System.out.println(e);

        }

        return null;
    }

}

Crime.java
public class Crime {

    private int crimeId;
    private String criminalName;
    private String crimeType;
    private String location;
    private String date;
    private String status;
    private String officerName;

    public Crime(){}

    public Crime(String criminalName,String crimeType,String location,
                 String date,String status,String officerName){

        this.criminalName=criminalName;
        this.crimeType=crimeType;
        this.location=location;
        this.date=date;
        this.status=status;
        this.officerName=officerName;
    }

    public String getCriminalName(){
        return criminalName;
    }

    public String getCrimeType(){
        return crimeType;
    }

    public String getLocation(){
        return location;
    }

    public String getDate(){
        return date;
    }

    public String getStatus(){
        return status;
    }

    public String getOfficerName(){
        return officerName;
    }

}

CrimeDAO.java

import java.sql.*;

public class CrimeDAO {

    public void addCrime(Crime crime){

        try{

            Connection con=DBConnection.getConnection();

            String sql="INSERT INTO crime_records(criminal_name,crime_type,location,date,status,officer_name) VALUES(?,?,?,?,?,?)";

            PreparedStatement ps=con.prepareStatement(sql);

            ps.setString(1,crime.getCriminalName());
            ps.setString(2,crime.getCrimeType());
            ps.setString(3,crime.getLocation());
            ps.setString(4,crime.getDate());
            ps.setString(5,crime.getStatus());
            ps.setString(6,crime.getOfficerName());

            ps.executeUpdate();

            System.out.println("Crime Record Added Successfully");

            con.close();

        }

        catch(Exception e){

            System.out.println(e);

        }

    }

}

Main.java

import java.util.Scanner;

public class Main {

    public static void main(String[] args){

        Scanner sc=new Scanner(System.in);

        CrimeDAO dao=new CrimeDAO();

        while(true){

            System.out.println("\nCrime Records Management");

            System.out.println("1.Add Crime");

            System.out.println("2.Exit");

            int choice=sc.nextInt();

            sc.nextLine();

            switch(choice){

                case 1:

                    System.out.print("Criminal Name: ");
                    String name=sc.nextLine();

                    System.out.print("Crime Type: ");
                    String type=sc.nextLine();

                    System.out.print("Location: ");
                    String location=sc.nextLine();

                    System.out.print("Date (YYYY-MM-DD): ");
                    String date=sc.nextLine();

                    System.out.print("Status: ");
                    String status=sc.nextLine();

                    System.out.print("Officer Name: ");
                    String officer=sc.nextLine();

                    Crime crime=new Crime(name,type,location,date,status,officer);

                    dao.addCrime(crime);

                    break;

                case 2:
                    System.exit(0);

            }

        }

    }

}



